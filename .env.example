# Copy this file to `.env.local` and fill in values from
# Supabase Dashboard → Project Settings → API (ca-central-1 project).
# Never commit `.env.local`. SUPABASE_SERVICE_ROLE_KEY is server-only.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here_server_only
